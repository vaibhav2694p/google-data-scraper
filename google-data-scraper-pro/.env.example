# Flask
SECRET_KEY=your-secret-key

# Scraper limits
MAX_SCROLL_ROUNDS=100
MAX_RESULTS=500
REQUEST_DELAY=1.0

# Server
HOST=0.0.0.0
PORT=5000
DEBUG=true

# Ollama (optional — leave OLLAMA_ENABLED=false to skip)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=
